<Window x:Class="slepamapa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:slepamapa"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">


    <TextBlock x:Name="Mesta"
               FontSize="25"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               Margin="0, 20, 0,0"/>

    <Button Content="Praha"
               Click="City_Click"
               Tag="Praha"
               Margin="200,150,0,0"
               Width="80"
               Height="40"/>


    <Button Content="Brno"
            Click="City_Click"
            Tag="Brno"
            Margin="300,250,0,0"
            Width="80"
            Height="40"/>

    <Button Content="Ostrava"
            Click="City_Click"
            Tag="Brno"
            Margin="300,250,0,0"
            Width="80"
            Height="40"/>




</Window>
