<Window x:Class="ProjektSlepaMapaDruhak.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Slepá mapa ČR" Height="650" Width="800">
    <Grid>
        <StackPanel Margin="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <TextBlock Text="Hledej město: " FontSize="18"/>
                <TextBlock x:Name="txtAktivniMesto" Text="---" FontSize="18" FontWeight="Bold" Foreground="Blue"/>
                <TextBlock Text=" | Skóre: " FontSize="18" Margin="20,0,0,0"/>
                <TextBlock x:Name="txtSkore" Text="0" FontSize="18" FontWeight="Bold"/>
            </StackPanel>

            <Canvas x:Name="mapCanvas" Width="700" Height="450" Background="White" 
                    MouseLeftButtonDown="MapCanvas_MouseLeftButtonDown" HorizontalAlignment="Center">

                <Image Source="pack://application:,,,/mapa_cr.jpg" Width="700" Height="450" Stretch="Fill"/>

            </Canvas>

            <TextBlock Text="Klikni do mapy pro zjištění souřadnic." FontStyle="Italic" HorizontalAlignment="Center" Margin="10"/>
        </StackPanel>
    </Grid>
</Window>